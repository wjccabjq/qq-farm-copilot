{
  "window_shortcut_path": "",
  "window_shortcut_launch_delay_seconds": 3,
  "window_restart_delay_seconds": 5,
  "window_title_keyword": "QQ经典农场",
  "window_select_rule": "auto",
  "safety": {
    "random_delay_min": 0.1,
    "random_delay_max": 0.3,
    "click_offset_range": 5,
    "max_actions_per_round": 20,
    "run_mode": "background",
    "debug_log_enabled": false
  },
  "screenshot": {
    "capture_interval_seconds": 0.3
  },
  "tasks": {
    "main": {
      "enabled": true,
      "trigger": "interval",
      "interval_seconds": 60,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 30,
      "features": {
        "auto_harvest": true,
        "auto_plant": false,
        "auto_weed": true,
        "auto_water": true,
        "auto_bug": true,
        "auto_expand": true,
        "auto_upgrade": true,
        "auto_fertilize": false
      }
    },
    "friend": {
      "enabled": true,
      "trigger": "interval",
      "interval_seconds": 1800,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 60,
      "features": {
        "auto_steal": false,
        "steal_enabled_time_range": "00:00:00-23:59:59",
        "steal_limit_count": 0,
        "auto_help": true,
        "help_enabled_time_range": "00:00:00-23:59:59",
        "help_limit_count": 0,
        "auto_accept_request": true,
        "blacklist": [],
        "steal_stats": false
      }
    },
    "share": {
      "enabled": true,
      "trigger": "daily",
      "interval_seconds": 86400,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 300,
      "features": {}
    },
    "reward": {
      "enabled": true,
      "trigger": "interval",
      "interval_seconds": 21600,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 300,
      "features": {
        "claim_growth_task": false,
        "claim_daily_task": true
      }
    },
    "gift": {
      "enabled": true,
      "trigger": "daily",
      "interval_seconds": 86400,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 300,
      "features": {
        "auto_svip_gift": true,
        "auto_mall_gift": true,
        "auto_mail": true
      }
    },
    "event_shop": {
      "enabled": true,
      "trigger": "daily",
      "interval_seconds": 86400,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["10:01", "20:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 300,
      "features": {}
    },
    "sell": {
      "enabled": true,
      "trigger": "interval",
      "interval_seconds": 21600,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 300,
      "features": {}
    },
    "land_scan": {
      "enabled": false,
      "trigger": "interval",
      "interval_seconds": 1800,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 300,
      "features": {}
    },
    "restart": {
      "enabled": false,
      "trigger": "interval",
      "interval_seconds": 14400,
      "enabled_time_range": "00:00:00-23:59:59",
      "daily_times": ["00:01"],
      "next_run": "2026-01-01 00:00",
      "failure_interval_seconds": 300,
      "features": {}
    }
  },
  "executor": {
    "min_task_interval_seconds": 5,
    "task_order": "land_scan>main>friend>sell>reward>gift>event_shop>share>restart",
    "default_success_interval": 5,
    "default_failure_interval": 5
  },
  "recovery": {
    "task_restart_attempts": 3,
    "task_retry_delay_seconds": 1,
    "startup_retry_step_sleep_seconds": 0.5,
    "startup_stabilize_timeout_seconds": 90.0
  },
  "planting": {
    "strategy": "latest_level",
    "warehouse_first": true,
    "skip_event_crops": false,
    "preferred_crop": "白萝卜",
    "player_level": 10,
    "level_ocr_enabled": true,
    "window_platform": "qq",
    "window_screen_index": 0,
    "window_position": "left_center",
    "virtual_desktop_index": 0,
    "planting_stable_seconds": 0.5,
    "planting_stable_timeout_seconds": 3.0,
    "land_swipe_right_times": 4,
    "land_swipe_left_times": 6
  },
  "land": {
    "countdown_sync_time": "",
    "plots": [],
    "profile": {
      "level": 0,
      "gold": "",
      "coupon": "",
      "exp": ""
    }
  },
  "sell": {
    "mode": "batch_all"
  }
}
